import time
import cv2
import mediapipe as mp
from pathlib import Path

BaseOptions = mp.tasks.BaseOptions
HandLandmarker = mp.tasks.vision.HandLandmarker
HandLandmarkerOptions = mp.tasks.vision.HandLandmarkerOptions
VisionRunningMode = mp.tasks.vision.RunningMode

MODEL_PATH = str(Path(__file__).resolve().parent.parent / "model" / "hand_landmarker.task")

options = HandLandmarkerOptions(
    base_options=BaseOptions(model_asset_path=MODEL_PATH),
    running_mode=VisionRunningMode.VIDEO,
    num_hands=2,
)

cap = cv2.VideoCapture(0)

with HandLandmarker.create_from_options(options) as landmarker:
    frame_idx = 0
    while True:
        ok, frame_bgr = cap.read()
        if not ok:
            continue

        frame_rgb = cv2.cvtColor(frame_bgr, cv2.COLOR_BGR2RGB)
        mp_image = mp.Image(image_format=mp.ImageFormat.SRGB, data=frame_rgb)

        # timestamp must be monotonically increasing (ms)
        timestamp_ms = int(frame_idx * 1000 / max(cap.get(cv2.CAP_PROP_FPS), 30))
        frame_idx += 1

        result = landmarker.detect_for_video(mp_image, timestamp_ms)

        if result.hand_landmarks:
            h, w = frame_bgr.shape[:2]
            for hand in result.hand_landmarks:
                for lm in hand:
                    cx, cy = int(lm.x * w), int(lm.y * h)
                    cv2.circle(frame_bgr, (cx, cy), 3, (0, 255, 0), -1)
            print("HAND DETECTED")
        else:
            print("No hand")

        cv2.imshow("Hand tracker", frame_bgr)
        if cv2.waitKey(1) & 0xFF == ord("q"):
            break

cap.release()
cv2.destroyAllWindows()
